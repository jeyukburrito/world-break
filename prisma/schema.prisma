generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String        @id @db.Uuid
  guestTokenHash  String?       @unique
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  games      Game[]
  decks      Deck[]
  matches    MatchResult[]
  tournaments TournamentSession[]

  @@map("users")
}

model Game {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  decks      Deck[]

  @@unique([userId, name])
  @@index([userId])
  @@map("games")
}

model Deck {
  id         String        @id @default(uuid()) @db.Uuid
  userId     String        @db.Uuid
  gameId     String        @db.Uuid
  name       String
  color      String?
  memo       String?
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  game       Game          @relation(fields: [gameId], references: [id], onDelete: Restrict)
  matches    MatchResult[]
  tournaments TournamentSession[]

  @@unique([userId, gameId, name])
  @@index([userId, gameId, isActive])
  @@map("decks")
}

model MatchResult {
  id               String           @id @default(uuid()) @db.Uuid
  userId           String           @db.Uuid
  myDeckId         String           @db.Uuid
  tournamentSessionId String?       @db.Uuid
  bo3PlaySequence  String?
  playedAt         DateTime
  opponentDeckName String
  eventCategory    EventCategory    @default(friendly)
  tournamentPhase  TournamentPhase?
  playOrder        PlayOrder
  didChoosePlayOrder Boolean        @default(false)
  matchFormat      MatchFormat
  wins             Int
  losses           Int
  isMatchWin       Boolean
  memo             String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  myDeck           Deck             @relation(fields: [myDeckId], references: [id], onDelete: Restrict)
  tournamentSession TournamentSession? @relation(fields: [tournamentSessionId], references: [id], onDelete: SetNull)

  @@index([userId, playedAt])
  @@index([userId, eventCategory, playedAt])
  @@index([userId, myDeckId, playedAt])
  @@index([userId, opponentDeckName])
  @@index([userId, playOrder])
  @@index([userId, matchFormat])
  @@index([userId, tournamentSessionId])
  @@map("match_results")
}

model TournamentSession {
  id            String           @id @default(uuid()) @db.Uuid
  userId        String           @db.Uuid
  myDeckId      String           @db.Uuid
  eventCategory EventCategory
  name          String?
  scorecardUrl  String?
  playedOn      DateTime
  endedAt       DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  myDeck        Deck             @relation(fields: [myDeckId], references: [id], onDelete: Cascade)
  matches       MatchResult[]

  @@index([userId, playedOn, eventCategory])
  @@index([userId, endedAt])
  @@map("tournament_sessions")
}

enum PlayOrder {
  first
  second
}

enum MatchFormat {
  bo1
  bo3
}

enum EventCategory {
  friendly
  shop
}

enum TournamentPhase {
  swiss
  elimination
}
